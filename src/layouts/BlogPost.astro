---
import type { MarkdownHeading } from "astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

import RelatedPosts from "@components/RelatedPosts.astro";
import TagsCloud from "@components/TagsCloud.astro";
import Layout from "@layouts/Base.astro";

import { getReadingTime, slugify } from "@utils/utils";

interface Props {
  post: CollectionEntry<"blog">;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props as Props;
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const {
  title,
  description,
  date,
  updatedDate,
  category,
  author,
  cover,
  coverAlt,
  tags,
} = post.data;

const dateFormatOptions: Intl.DateTimeFormatOptions = {
  year: "numeric",
  month: "long",
  day: "numeric",
  // YAML parses bare dates as midnight UTC; pin formatting to UTC so the rendered day matches the frontmatter
  // Otherwise, toLocaleDateString uses the build machine's timezone and can shift the rendered day by one
  timeZone: "UTC",
};

const dateIso = date.toISOString();
const formattedDate = date.toLocaleDateString("en-GB", dateFormatOptions);
const updatedDateIso = updatedDate?.toISOString();
const formattedUpdatedDate = updatedDate?.toLocaleDateString(
  "en-GB",
  dateFormatOptions,
);

const readingTime = getReadingTime(post.body ?? "");
---

<Layout
  {title}
  {description}
  image={`/open-graph/${post.id}.png`}
  type="article"
>
  <main class="mx-auto my-8 max-w-5xl lg:my-12">
    <section class="mx-8 mb-8">
      <p class="text-fg-muted mb-2 text-2xl">
        <a
          class="hover:text-accent transition"
          href={`/blog/categories/${slugify(category)}`}>{category}</a
        >
      </p>

      <h1 class="mb-2 text-4xl">
        {title}
      </h1>

      <p class="text-fg-muted mb-4 flex flex-wrap items-center gap-x-4">
        <span class="inline-flex items-center gap-1">
          <Icon name="mdi:person" aria-hidden="true" />
          {author}
        </span>
        <span class="inline-flex items-center gap-1">
          <Icon name="mdi:calendar-check-outline" aria-hidden="true" />
          <time datetime={dateIso}>{formattedDate}</time>
        </span>
        <span class="inline-flex items-center gap-1">
          <Icon name="mdi:clock-outline" aria-hidden="true" />
          {readingTime} min read
        </span>
        {
          updatedDate && (
            <span class="inline-flex items-center gap-1">
              <Icon name="mdi:calendar-refresh-outline" aria-hidden="true" />
              <span class="italic">
                Last updated:
                <time datetime={updatedDateIso}>{formattedUpdatedDate}</time>
              </span>
            </span>
          )
        }
      </p>

      <Image
        src={cover}
        alt={coverAlt}
        layout="constrained"
        width={1200}
        priority
        class="w-full rounded-xl"
        transition:name={`image_${post.id}`}
      />
    </section>

    <section class="mx-8 mb-12">
      {
        tocHeadings.length > 0 && (
          <nav class="mb-8" aria-label="Table of contents">
            <p class="text-fg-muted mb-2 text-sm font-medium tracking-wider uppercase">
              On this page
            </p>
            <ol class="border-fg-muted/30 space-y-1 border-l pl-4">
              {tocHeadings.map((h) => (
                <li class={h.depth === 3 ? "ml-4" : ""}>
                  <a
                    href={`#${h.slug}`}
                    class="hover:text-accent font-mono text-sm transition"
                  >
                    {h.text}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        )
      }
      <div class="post-body">
        <slot>This post seems to be missing...</slot>
      </div>
    </section>

    <div class="mx-8 flex items-start justify-start gap-12">
      <aside class="basis-3/5">
        <h2 class="mb-2 text-2xl">Related Posts</h2>
        <RelatedPosts originalPost={post} postsToDisplay={4} />
      </aside>

      <aside class="max-w-max basis-2/5">
        <h2 class="mb-2 text-2xl">Tags</h2>
        <TagsCloud postTags={tags} />
      </aside>
    </div>
  </main>
</Layout>
