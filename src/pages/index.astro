---
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import { getCollection } from "astro:content";

import { contactEmail, contactLinks } from "@data/contactLinks";
import { projects } from "@data/projects";
import { technologies } from "@data/technologies";
import { filterPosts } from "@utils/utils";

import cka from "@assets/images/badges/cka-certified-kubernetes-administrator.png";
import headshot from "@assets/images/headshot/headshot.jpg";
import PostCard from "@components/PostCard.astro";
import ProjectCard from "@components/ProjectCard.astro";
import Layout from "@layouts/Base.astro";

const allPosts = await getCollection("blog");
const postsToDisplay = filterPosts(allPosts, { limit: 3 });
---

<Layout title="Murtadha - Home">
  <main class="mx-auto my-16 max-w-5xl">
    <section
      class="mx-8 mb-12 grid grid-cols-1 gap-10 lg:grid-cols-[1fr_15rem] lg:gap-x-16"
      aria-label="About Me"
    >
      <!-- display: contents on mobile makes the wrapper invisible so its children
       (image + socials) participate individually in the grid with order-last pushing
       socials to the bottom. At md+, display: flex kicks in and groups them together. -->
      <div
        class="contents sm:flex sm:flex-row sm:items-center sm:gap-16 lg:order-last lg:flex-col lg:items-start lg:gap-8"
      >
        <Image
          src={headshot}
          alt="My personal photo"
          layout="constrained"
          width={256}
          priority
          class="max-w-64 shrink-0 rotate-3 justify-self-center rounded-xl lg:w-full lg:max-w-none"
        />

        <ul
          class="order-last flex flex-col items-start gap-4 md:order-0"
          aria-label="Social media accounts and email"
        >
          {
            contactLinks.map((contactLink) => (
              <li>
                <a
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group hover:text-accent flex items-center gap-4 text-sm font-medium transition"
                  href={contactLink.path}
                >
                  <span class="flex w-6 items-center justify-center">
                    <Icon
                      class="text-fg-muted group-hover:text-accent transition"
                      name={contactLink.icon}
                      size={contactLink.size ?? 24}
                    />
                  </span>
                  <span>{contactLink.label}</span>
                </a>
              </li>
            ))
          }
          <li class="border-fg-muted/50 mt-2 self-stretch border-t pt-6">
            <a
              href={"mailto:" + contactEmail.path}
              class="group hover:text-accent flex items-center gap-4 text-sm font-medium transition"
            >
              <span class="flex w-6 items-center justify-center">
                <Icon
                  class="text-fg-muted group-hover:text-accent transition"
                  name={contactEmail.icon}
                  size={24}
                />
              </span>
              <span>{contactEmail.label}</span>
            </a>
          </li>
        </ul>
      </div>

      <div class="min-w-0">
        <h1 class="mb-4 text-4xl font-bold">Hey, I'm Murtadha</h1>
        <p class="text-fg-muted mb-2">
          I'm a software / infrastructure engineer currently based in Jordan 🇯🇴
          I'm familiar with a variety of web technologies and DevOps techniques.
          I'm passionate about self-hosting, IaC tooling, GitOps, and
          automation.
        </p>
        <p class="text-fg-muted mb-4">
          I have a first-class BSc (Hons) degree in Computing and IT from the
          UK, where I have previously lived for over 7 years. My general area of
          focus is web development and infrastructure. I have recently passed
          the Certified Kubernetes Administrator (CKA) exam and have been
          exploring the cloud native ecosystem.
        </p>

        <div class="grid grid-cols-1 gap-4 md:grid-cols-[3fr_2fr] md:gap-x-6">
          <div>
            <h2 class="mb-4 text-2xl">Technologies and tools</h2>
            <ul class="flex flex-wrap items-center gap-4">
              {
                technologies.map((technology) => (
                  <li>
                    <Icon
                      class="hover:text-accent dark:text-fg-muted transition"
                      name={technology.icon}
                      size={40}
                    />
                  </li>
                ))
              }
            </ul>
          </div>

          <div>
            <h2 class="mb-2 text-2xl">Certifications</h2>
            <ul class="flex flex-wrap items-center gap-4">
              <li>
                <a
                  href="https://www.credly.com/badges/cb9770f2-39b2-4bdc-bc38-3815c34724cb/public_url"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Image
                    src={cka}
                    alt="CKA badge"
                    width={96}
                    densities={[1, 2]}
                    class="w-24"
                  />
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section
      id="projects"
      aria-label="Projects"
      class="mx-8 mb-12 scroll-mt-24"
    >
      <h2 class="mb-6 text-center text-3xl md:text-4xl">Projects</h2>
      <ul class="grid grid-cols-1 gap-4 md:grid-cols-2">
        {
          projects.map((project) => (
            <li class="h-full">
              <ProjectCard project={project} />
            </li>
          ))
        }
      </ul>
    </section>

    <section aria-label="Latest Blog Posts" class="mx-8">
      <h2 class="mb-6 text-center text-3xl md:text-4xl">Latest Articles</h2>
      <ul class="space-y-8">
        {
          postsToDisplay.map((post) => (
            <li>
              <PostCard post={post} maxTags={3} />
            </li>
          ))
        }
      </ul>
    </section>
  </main>
</Layout>
