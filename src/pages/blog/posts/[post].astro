---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";

import BlogPost from "@layouts/BlogPost.astro";

import H2 from "@components/posts/H2.astro";
import H3 from "@components/posts/H3.astro";
import P from "@components/posts/P.astro";
import { filterPosts } from "@utils/utils";

// generate a static path for each blog post
export const getStaticPaths = async () => {
  const allPosts = await getCollection("blog");
  const postsToDisplay = filterPosts(allPosts);
  return postsToDisplay.map((post) => ({
    params: { post: post.id },
    props: { post },
  }));
};

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props as Props;
const { Content } = await render(post);
---

<BlogPost {post}>
  <Content components={{ h2: H2, h3: H3, p: P }} />
</BlogPost>
