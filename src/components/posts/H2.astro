---
import { Icon } from "astro-icon/components";
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"h2">;

const { id, class: className, ...attrs } = Astro.props;
---

<h2 {...attrs} {id} class:list={["group scroll-mt-4 text-3xl", className]}>
  <slot />{
    id && (
      <a
        href={`#${id}`}
        aria-label="Link to this section"
        class="hover:text-accent inline-flex items-center pl-2 align-middle no-underline opacity-0 transition-opacity group-hover:opacity-100 focus-visible:opacity-100"
      >
        <Icon name="mdi:link-variant" class="text-[0.85em]" />
      </a>
    )
  }
</h2>
